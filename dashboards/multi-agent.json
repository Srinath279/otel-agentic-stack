{
  "title": "Agentic — Multi-Agent & Sub-Agents",
  "uid": "agent-multi",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Runs/min by service (each agent = a service.name)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (service_name) (rate(agent_run_duration_seconds_count[5m])) * 60", "legendFormat": "{{service_name}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Tokens/min by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (service_name) (rate(gen_ai_client_token_usage_total[5m])) * 60", "legendFormat": "{{service_name}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Runs/min by agent role (coordinator + sub-agents)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (agent_name) (rate(agent_run_duration_seconds_count[5m])) * 60", "legendFormat": "{{agent_name}}" }
      ]
    },
    {
      "id": 4,
      "type": "piechart",
      "title": "Run share by agent role",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (agent_name) (rate(agent_run_duration_seconds_count[5m]))", "legendFormat": "{{agent_name}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Agent-run p95 by role (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, agent_name) (rate(agent_run_duration_seconds_bucket[5m])))", "legendFormat": "{{agent_name}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Tool calls/min by agent role + tool",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (agent_name, tool) (rate(agent_tool_calls_total[5m])) * 60", "legendFormat": "{{agent_name}}/{{tool}}" }
      ]
    }
  ]
}
